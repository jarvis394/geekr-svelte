{
	"name": "geekr-ssr",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:android": "cross-env CAPACITOR_DEV=true cap run android",
		"build": "vite build",
		"build:android": "bun run build && cross-env CAPACITOR_DEV=false cap sync && cap build android --androidreleasetype APK",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"icons:android": "bunx capacitor-assets generate --android"
	},
